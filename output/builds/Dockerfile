# SentinelForge Edge Pipeline - Multi-stage Docker Build
# Generated by Agent 13 (Docker Builder)
# Target: NVIDIA Jetson AGX Orin 64GB
# CUDA: 12.2
# OS: Ubuntu 22.04 LTS

# ===== Stage 1: Build C++/CUDA code =====
FROM nvcr.io/nvidia/cuda:12.2.0-devel-ubuntu22.04 AS builder

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential cmake git \
    libopencv-dev libcfitsio-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY src/ ./src/

# Compile CUDA kernels
RUN nvcc -O3 -arch=sm_87 \
    src/calibration.cu \
    src/streak_detect.cu \
    -shared -o libsentinel_gpu.so \
    -Xcompiler -fPIC

# Compile C++ drivers
RUN g++ -O3 -std=c++17 \
    src/camera_driver.cpp \
    src/mount_control.cpp \
    src/plate_solver.cpp \
    src/photometry.cpp \
    -shared -o libsentinel_hw.so \
    -fPIC -lpthread

# ===== Stage 2: Python runtime =====
FROM nvcr.io/nvidia/cuda:12.2.0-runtime-ubuntu22.04 AS runtime

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 python3-pip \
    libopencv-core4.5d libcfitsio9 \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies
RUN pip3 install --no-cache-dir \
    numpy scipy astropy \
    torch torchvision --index-url https://download.pytorch.org/whl/cu121 \
    opencv-python-headless \
    onnxruntime-gpu \
    requests

WORKDIR /app

# Copy compiled libraries from builder
COPY --from=builder /build/libsentinel_gpu.so /app/lib/
COPY --from=builder /build/libsentinel_hw.so /app/lib/

# Copy Python pipeline
COPY src/*.py /app/
COPY config/ /app/config/

# Data directories
RUN mkdir -p /data/raw /data/calibrated /data/detections \
             /data/thumbnails /data/catalog /data/darks /data/flats \
             /logs

# Environment
ENV LD_LIBRARY_PATH=/app/lib:$LD_LIBRARY_PATH
ENV PYTHONUNBUFFERED=1
ENV SITE_ID=UNSET
ENV CUDA_VISIBLE_DEVICES=0

# Health check
HEALTHCHECK --interval=60s --timeout=10s --retries=3 \
    CMD python3 /app/health_check.py || exit 1

EXPOSE 8080

ENTRYPOINT ["python3", "/app/autonomous.py"]
CMD ["--site-config", "/app/config/site.json"]
